Import("env")

nval_inc = ["#plugin/nvAL/src"]

if ARGUMENTS.get("no_shared_plugins", "0") == "0":
    env.SharedLibrary("#release/lib/nval", ["src/nval.cpp"], CPPPATH=env["CPPPATH"] + nval_inc)
static = env.Object("nval_static", "src/nval.cpp",
    CPPDEFINES=env["CPPDEFINES"] + [("NVGT_PLUGIN_STATIC", "nval")],
    CPPPATH=env["CPPPATH"] + nval_inc)
static = env.StaticLibrary("#build/lib/nval", [static])
Return("static")
